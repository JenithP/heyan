rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasProfile() {
      return isSignedIn() && exists(userDoc(request.auth.uid));
    }

    function currentProfile() {
      return get(userDoc(request.auth.uid));
    }

    function isAdmin() {
      return hasProfile() && currentProfile().data.type in ['admin', 'manager'];
    }

    function isActiveProfile(uid) {
      return exists(userDoc(uid))
        && get(userDoc(uid)).data.type in ['member', 'manager', 'admin'];
    }

    function isPrimaryAdminRequest() {
      return isSignedIn() && request.auth.token.email == 'leily.yoon@gmail.com';
    }

    function validRoom(roomId) {
      return roomId in [
        '4seat_1', '4seat_2', '4seat_3', '4seat_4', '4seat_5', '4seat_6', '4seat_7',
        '6seat_1', '6seat_2', '6seat_3',
        'meeting', 'room',
        'all'
      ];
    }

    function validSlot(slot) {
      return slot in ['s1', 's2', 's3', 's4', 's5'];
    }

    function validStatus(status) {
      return status in ['pending', 'approved', 'cancelled'];
    }

    function validUserKeys() {
      return request.resource.data.keys().hasOnly([
        'uid', 'email', 'phone', 'name', 'section', 'role', 'type',
        'createdAt', 'updatedAt',
        'promotedAt', 'promotedBy', 'demotedAt', 'demotedBy',
        'deletedAt', 'deletedBy'
      ]);
    }

    function validUserBase(userId) {
      return validUserKeys()
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.type in ['member', 'manager', 'admin', 'deleted'];
    }

    function validUserCreate(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && validUserBase(userId)
        && (
          request.resource.data.type == 'member'
          || (request.resource.data.type == 'admin' && isPrimaryAdminRequest())
        );
    }

    function validSelfUserUpdate(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && validUserBase(userId)
        && request.resource.data.type == resource.data.type
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'phone', 'section', 'role', 'updatedAt'
        ]);
    }

    function validAdminUserUpdate(userId) {
      return isAdmin()
        && validUserKeys()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.type in ['member', 'manager', 'admin', 'deleted']
        && (resource.data.email != 'leily.yoon@gmail.com' || request.resource.data.type == 'admin')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'type', 'role',
          'promotedAt', 'promotedBy', 'demotedAt', 'demotedBy',
          'deletedAt', 'deletedBy', 'updatedAt'
        ]);
    }

    function validBookingCreate() {
      return hasProfile()
        && request.resource.data.keys().hasOnly([
          'date', 'roomId', 'slot',
          'userId', 'userEmail', 'userPhone', 'userName',
          'status', 'isManager', 'createdAt',
          'headcount', 'purpose'
        ])
        && request.resource.data.date is string
        && validRoom(request.resource.data.roomId)
        && validSlot(request.resource.data.slot)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email
        && request.resource.data.userPhone is string
        && request.resource.data.userName is string
        && (!('headcount' in request.resource.data) || request.resource.data.headcount is int)
        && (!('purpose' in request.resource.data) || request.resource.data.purpose is string)
        && isActiveProfile(request.auth.uid)
        && (
          (request.resource.data.status == 'pending' && request.resource.data.isManager == false)
          || (request.resource.data.status == 'approved' && request.resource.data.isManager == true && isAdmin())
        );
    }

    function validBookingUpdateBase() {
      return request.resource.data.keys().hasOnly([
          'date', 'roomId', 'slot',
          'userId', 'userEmail', 'userPhone', 'userName',
          'status', 'isManager', 'createdAt',
          'headcount', 'purpose',
          'approvedAt', 'approvedBy', 'approvedByEmail',
          'cancelledAt', 'cancelledBy', 'cancelledByEmail', 'cancelReason',
          'price'
        ])
        && validStatus(request.resource.data.status)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'approvedAt', 'approvedBy', 'approvedByEmail',
          'cancelledAt', 'cancelledBy', 'cancelledByEmail', 'cancelReason'
        ]);
    }

    function validOwnerBookingCancel() {
      return hasProfile()
        && resource.data.userId == request.auth.uid
        && request.resource.data.status == 'cancelled'
        && validBookingUpdateBase();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if validUserCreate(userId);
      allow update: if validSelfUserUpdate(userId) || validAdminUserUpdate(userId);
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if hasProfile();
      allow create: if validBookingCreate();
      allow update: if (isAdmin() && validBookingUpdateBase()) || validOwnerBookingCancel();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
